{
  "name": "echarts-internal",
  "version": "1.0.1",
  "description": "Zero-config DAG flow visualizer for ECharts — drop-in critical path analysis, barycenter layout, and interactive filtering for Grafana Business Charts panels",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "npm run build && storybook build",
    "test-storybook": "test-storybook",
    "cdn:refresh": "for p in graphs/index.ts graphs/gantt/index.ts graphs/flow-graph/index.ts; do curl -s \"https://esm.sh/gh/ProjectBarks/echarts@main/$p?bundle&refresh\" > /dev/null; done && curl -sI \"https://esm.sh/gh/ProjectBarks/echarts@main/graphs/index.ts?bundle\" | grep -i x-esm-path"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./flow-graph": {
      "types": "./dist/graphs/flow-graph/index.d.ts",
      "import": "./dist/graphs/flow-graph/index.js",
      "default": "./dist/graphs/flow-graph/index.js"
    },
    "./gantt": {
      "types": "./dist/graphs/gantt/index.d.ts",
      "import": "./dist/graphs/gantt/index.js",
      "default": "./dist/graphs/gantt/index.js"
    }
  },
  "keywords": [
    "echarts",
    "dag",
    "directed-acyclic-graph",
    "graph",
    "visualization",
    "grafana",
    "business-charts",
    "critical-path",
    "flow",
    "task-flow",
    "node-graph",
    "barycenter",
    "layout",
    "observability",
    "latency"
  ],
  "author": "ProjectBarks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ProjectBarks/echarts-internal.git"
  },
  "homepage": "https://github.com/ProjectBarks/echarts-internal#readme",
  "bugs": {
    "url": "https://github.com/ProjectBarks/echarts-internal/issues"
  },
  "devDependencies": {
    "@storybook/html-vite": "^8.6.18",
    "@storybook/test-runner": "^0.19.1",
    "echarts": "^5.6.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "storybook": "^8.6.18",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.1.9",
    "wait-on": "^7.2.0"
  }
}
